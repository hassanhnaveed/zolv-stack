# NEXT_PUBLIC_* vars are exposed to the browser. Do not put secrets here.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Drive picker (browser-safe; restrict by HTTP referrer / JS origin in Google Cloud)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
# Optional — Cloud project number for Picker. If omitted, derived from CLIENT_ID prefix.
NEXT_PUBLIC_GOOGLE_APP_ID=

# Microsoft Clarity (browser analytics). Leave empty to disable.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# SEO (lib/seo/*, SEO Architecture v1.0). Server-only — never prefix with
# NEXT_PUBLIC_. Fail-closed: indexing stays off unless every condition below
# is met (see docs/seo/url-policy.md and lib/seo/config.ts).
# Explicit opt-in to allow indexing. Only takes effect in a recognized
# production environment (NODE_ENV=production + a valid NEXT_PUBLIC_APP_URL).
# Even when true: the initial tool index allowlist is empty (Task 9 — see
# lib/seo/routes.ts, TOOL_ROUTE_DEFAULTS). Only Home and the Fileora hub
# are declared indexable today; tools opt in individually after passing the
# index quality gate. See docs/seo/search-console.md and rollback.md.
SEO_INDEXING_ENABLED=false
# Google Search Console verification token (native `verification.google`
# metadata field). Leave empty until a real domain property exists;
# placeholder/example values are rejected — never emitted, and fail
# `npm run seo:check` (see lib/seo/verification.ts:
# isPlaceholderVerificationToken). See docs/seo/search-console.md.
SEO_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools verification token (emitted as the `msvalidate.01`
# meta tag; Next has no native Bing verification field). Leave empty until
# configured — prefer importing the property from Search Console first
# (see docs/seo/search-console.md).
SEO_BING_SITE_VERIFICATION=
